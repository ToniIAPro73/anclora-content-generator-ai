DATABASE_URL=postgresql://user:password@endpoint.neon.tech/database?sslmode=require
# Local only. In production the browser should resolve against the deployed origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Local only. In Vercel set this to your real deployment domain if you need to override auto-detection.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_ENABLED=true
NEXT_PUBLIC_BETTER_AUTH_ENABLED=true
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# RAG runtime actual
RAG_VECTOR_BACKEND=pgvector
RAG_EMBEDDING_BACKEND=local
RAG_SIMILARITY_THRESHOLD=0.7
RAG_TOP_K=5

# Preparado para escalado futuro con Pinecone + Gemini embeddings
GOOGLE_AI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_GENERATION_MODEL=gemini-2.0-flash
PINECONE_API_KEY=
PINECONE_INDEX_NAME=gemini-rag
